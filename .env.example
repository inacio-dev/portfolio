# =============================================================================
# Portfólio — Inácio Rodrigues — variáveis de ambiente de exemplo
# =============================================================================
# Copie este arquivo para .env (dev) ou configure no host (Vercel/Coolify)
# em produção. Variáveis com prefixo NEXT_PUBLIC_ são embutidas no bundle do
# browser — NUNCA coloque segredos em NEXT_PUBLIC_*.
# =============================================================================

# -----------------------------------------------------------------------------
# Google Tag Manager
# -----------------------------------------------------------------------------
# ID do container GTM no formato GTM-XXXXXXX (não o G-XXX do GA4 direto).
# Em dev, deixe vazio para NÃO carregar o GTM e evitar poluição na conta real.
# Em prod, configure no dashboard do host.
# O script só carrega após o usuário aceitar cookies no banner LGPD
# (components/CookieConsent.tsx).
NEXT_PUBLIC_GTM_ID=

# -----------------------------------------------------------------------------
# Cookies — domínio compartilhado
# -----------------------------------------------------------------------------
# Domínio usado pelo cookie de consentimento LGPD (portifolio-cookie-consent).
# Deixe VAZIO em dev (localhost não aceita domain explícito e quebra o cookie).
# Em prod, setar com ponto inicial para cobrir subdomínios:
#   NEXT_PUBLIC_COOKIE_DOMAIN=.inaciorodrigues.dev.br
NEXT_PUBLIC_COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# URL canônica do site (sitemap, robots, OG tags, canonical URLs, hreflang)
# -----------------------------------------------------------------------------
# Sem barra no final. Obrigatória — o build falha se não estiver definida.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Contato — para receber mensagens do formulário e exibir nas páginas
# -----------------------------------------------------------------------------
# Email público mostrado no rodapé e usado como `to` da server action de contato.
NEXT_PUBLIC_CONTACT_EMAIL=inaciormgalvao@outlook.com

# Número de WhatsApp (E.164, somente dígitos: 55 + DDD + número).
# Ex: +55 85 99827-7174  →  5585998277174
NEXT_PUBLIC_WHATSAPP_NUMBER=5585998277174

# Handles públicos
NEXT_PUBLIC_GITHUB_URL=https://github.com/inacio-dev
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/inacio-rodrigues-dev/

# -----------------------------------------------------------------------------
# SMTP — opcional. Server action de contato envia email se as 4 vars existirem
# -----------------------------------------------------------------------------
# Sem essas vars, a server action grava em log/console (modo dev).
# Use SMTP do Gmail (App Password), SendGrid, Resend, Mailgun etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# Cloudflare Turnstile — anti-spam invisível pro form de contato
# -----------------------------------------------------------------------------
# Crie sites.key+secret em https://dash.cloudflare.com/?to=/:account/turnstile
# Use widget mode "invisible". Sem essas vars, o form aceita sem challenge
# (modo dev). Em prod, configure as DUAS para bloquear bots.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
